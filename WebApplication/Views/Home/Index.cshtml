<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

@{
    var usuario = Session["Usuario"];
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div class="bg-light border rounded p-2 px-3 shadow-sm">
            <strong>@Session["Nome"]</strong><br />
            <small class="text-muted">CPF: @Session["CPF"]</small>
        </div>

        <a href="/Login/Logout" class="btn btn-danger">
            Sair
        </a>

    </div>

    <div class="text-center mb-5">
        <h1 class="text-primary fw-bold">Sistema de Gerenciamento de Estoque</h1>
        <p class="text-muted">Controle completo de produtos e movimentações</p>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm h-100 text-center p-3">
                <h5 class="mb-3">Produtos</h5>
                <a href="/Produto/Index" class="btn btn-primary w-100">
                    Gerenciar Produtos
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm h-100 text-center p-3">
                <h5 class="mb-3">Entrada</h5>
                <a href="/Movimentacao/Entrada" class="btn btn-success w-100">
                    Entrada de Produtos
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm h-100 text-center p-3">
                <h5 class="mb-3">Consumo</h5>
                <a href="/Movimentacao/Consumo" class="btn btn-warning w-100">
                    Consumo de Produtos
                </a>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm h-100 text-center p-3">
                <h5 class="mb-3">Transferência</h5>
                <a href="/Movimentacao/Transferencia" class="btn btn-info w-100 text-white">
                    Transferir Produto
                </a>
            </div>
        </div>
    </div>
</div>