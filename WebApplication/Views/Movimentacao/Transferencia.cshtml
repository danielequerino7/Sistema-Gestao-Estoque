@model WebApplication.ViewModel.MovimentacaoViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="position-relative mb-3 text-center">
        <a href="/Home/Index" class="btn btn-secondary position-absolute start-0">
            ← Voltar
        </a>
        <h2>Transferência entre Setores</h2>
    </div>

    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    @using (Html.BeginForm("Transferencia", "Movimentacao", FormMethod.Post))
    {
        <div class="row">

            <div class="col-md-6 mb-3">
                <label class="form-label">Produto</label>
                @Html.DropDownListFor(m => m.ProdutoId, Model.Produtos, "Selecione o produto", new { @class = "form-control" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Setor Origem</label>
                @Html.DropDownListFor(m => m.SetorOrigemId, Model.Setores, "Selecione o setor", new { @class = "form-control" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Setor Destino</label>
                @Html.DropDownListFor(m => m.SetorDestinoId, Model.Setores, "Selecione o setor", new { @class = "form-control" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Quantidade</label>
                @Html.TextBoxFor(m => m.Quantidade, new { @class = "form-control", type = "number" })
            </div>

        </div>

        <button type="submit" class="btn btn-info text-white">
            Transferir
        </button>
    }
</div>