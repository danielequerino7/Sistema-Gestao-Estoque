<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container vh-100 d-flex justify-content-center align-items-center">

    <div class="card shadow p-4" style="width: 100%; max-width: 400px;">

        <div class="text-center mb-4">
            <h3 class="text-primary">Login</h3>
            <p class="text-muted">Acesse o sistema</p>
        </div>

        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        @using (Html.BeginForm("Login", "Login", FormMethod.Post))
        {
            <div class="mb-3">
                <label class="form-label">CPF</label>
                @Html.TextBox("CPF", null, new { @class = "form-control", placeholder = "Digite seu CPF", id = "cpf"})
            </div>

            <div class="mb-3">
                <label class="form-label">Senha</label>
                @Html.Password("Senha", null, new { @class = "form-control", placeholder = "Digite sua senha" })
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Entrar
            </button>
        }

    </div>

</div>

<script>document.getElementById("cpf").addEventListener("input", function (e) {
        let value = e.target.value.replace(/\D/g, "");

        if (value.length > 11) value = value.slice(0, 11);

        value = value.replace(/(\d{3})(\d)/, "$1.$2");
        value = value.replace(/(\d{3})(\d)/, "$1.$2");
        value = value.replace(/(\d{3})(\d{1,2})$/, "$1-$2");

        e.target.value = value;
});</script>
