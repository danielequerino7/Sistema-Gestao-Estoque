@model WebApplication.ViewModel.EditarProdutoViewModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="position-relative mb-3 text-center">
        <a href="/Produto/Index" class="btn btn-secondary position-absolute start-0">
            ← Voltar
        </a>

        <h2>Editar Produto</h2>
    </div>

    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    @using (Html.BeginForm("Editar", "Produto", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="row">
            <div class="col-md-6 mb-3" color="gray">
                <label class="form-label">SKU</label>
                @Html.TextBoxFor(m => m.Sku, new { @class = "form-control", @readonly = "readonly" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Nome</label>
                @Html.TextBoxFor(m => m.Nome, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Preço</label>
                @Html.TextBoxFor(m => m.Preco, new { @class = "form-control", placeholder = "Ex: 10,50" })
                @Html.ValidationMessageFor(m => m.Preco, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Quantidade</label>
                @Html.TextBoxFor(m => m.QuantidadeEmEstoque, new { @class = "form-control", type = "number" })
                @Html.ValidationMessageFor(m => m.QuantidadeEmEstoque, "", new { @class = "text-danger" })
            </div>

            <div class="col-12 mb-3">
                <label class="form-label">Descrição</label>
                @Html.TextAreaFor(m => m.Descricao, new { @class = "form-control", rows = 3 })
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">
                Atualizar Produto
            </button>
        </div>
    }
</div>